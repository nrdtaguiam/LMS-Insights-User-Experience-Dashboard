# API Settings
PROJECT_NAME="LMS Data Visualization API"
API_V1_STR="/api/v1"

# Blackboard API Credentials
BLACKBOARD_API_URL=https://developer.blackboard.com
BLACKBOARD_CLIENT_ID=your_client_id_here
BLACKBOARD_CLIENT_SECRET=your_client_secret_here

# PostgreSQL Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lms_data
POSTGRES_PORT=5432

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
